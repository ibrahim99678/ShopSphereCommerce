@model IReadOnlyList<ShopSphere.Web.Areas.Admin.Controllers.CategoryTreeItem>

@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center">
    <h2>Categories</h2>
    <a asp-area="Admin" asp-controller="Category" asp-action="Create" class="btn btn-primary">Create</a>
</div>

@if (TempData["Error"] is string error && !string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger mt-3">@error</div>
}

@if (!Model.Any())
{
    <p>No categories found.</p>
}
else
{
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>Name</th>
                <th>Slug</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@(new string('\u00A0', item.Depth * 4))@item.Name</td>
                <td>@item.Slug</td>
                <td class="text-end">
                    <a asp-area="Admin" asp-controller="Category" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form asp-area="Admin" asp-controller="Category" asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

