@model ShopSphere.Web.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center">
    <h2>Admin Dashboard</h2>
    <div class="d-flex gap-2">
        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-outline-secondary">Orders</a>
        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Products</a>
        <a asp-area="Admin" asp-controller="Inventory" asp-action="LowStock" class="btn btn-outline-secondary">Low Stock</a>
    </div>
</div>

<div class="row mt-3 g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="text-muted">Total Orders</div>
                <div class="fs-2 fw-semibold">@Model.TotalOrders</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="text-muted">Total Sales (Paid)</div>
                <div class="fs-2 fw-semibold">@Model.TotalSales.ToString("0.00")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="text-muted">Total Customers</div>
                <div class="fs-2 fw-semibold">@Model.TotalCustomers</div>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>Recent Orders</div>
        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body">
        @if (!Model.RecentOrders.Any())
        {
            <p class="mb-0">No orders found.</p>
        }
        else
        {
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Status</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var o in Model.RecentOrders)
                {
                    <tr>
                        <td class="text-break">@o.OrderNumber</td>
                        <td>@o.Status</td>
                        <td class="text-end">@o.Total.ToString("0.00")</td>
                        <td class="text-end">@o.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                        <td class="text-end">
                            <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>

