@model ShopSphere.Web.Models.LowStockViewModel

@{
    ViewData["Title"] = "Low Stock";
}

<div class="d-flex justify-content-between align-items-center">
    <h2>Low Stock</h2>
    <form asp-area="Admin" asp-controller="Inventory" asp-action="LowStock" method="get" class="d-flex gap-2">
        <input type="number" name="threshold" value="@Model.Threshold" class="form-control" style="width: 120px;" />
        <button type="submit" class="btn btn-outline-primary">Apply</button>
    </form>
</div>

@if (!Model.Items.Any())
{
    <p class="mt-3">No low stock items found.</p>
}
else
{
    <table class="table table-striped mt-3 align-middle">
        <thead>
            <tr>
                <th>Type</th>
                <th>Product</th>
                <th>Variant</th>
                <th class="text-end">Stock</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var i in Model.Items)
        {
            <tr>
                <td>@i.Type</td>
                <td class="text-break">@i.ProductName</td>
                <td class="text-break">@i.VariantLabel</td>
                <td class="text-end">@i.StockQuantity</td>
                <td class="text-end">
                    <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@i.ProductId" class="btn btn-sm btn-outline-primary">Open</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

