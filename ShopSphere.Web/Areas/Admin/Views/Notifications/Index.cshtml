@model IReadOnlyList<ShopSphere.Contract.Dtos.NotificationDto>

@{
    ViewData["Title"] = "Notifications";
    var unread = ViewBag.UnreadCount as int? ?? 0;
}

<div class="d-flex justify-content-between align-items-center">
    <h2>Notifications</h2>
    <div class="text-muted">Unread: @unread</div>
</div>

@if (!Model.Any())
{
    <p class="mt-3">No notifications.</p>
}
else
{
    <table class="table table-striped mt-3 align-middle">
        <thead>
            <tr>
                <th>Title</th>
                <th>Message</th>
                <th class="text-end">Date</th>
                <th class="text-end">Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var n in Model)
        {
            <tr>
                <td class="text-break fw-semibold">@n.Title</td>
                <td class="text-break">
                    <div>@n.Message</div>
                    @if (n.OrderId is not null)
                    {
                        <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@n.OrderId.Value" class="link-primary">View order</a>
                    }
                </td>
                <td class="text-end">@n.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                <td class="text-end">@((n.IsRead) ? "Read" : "Unread")</td>
                <td class="text-end">
                    @if (!n.IsRead)
                    {
                        <form asp-area="Admin" asp-controller="Notifications" asp-action="MarkRead" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@n.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-primary">Mark read</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}

