@model IReadOnlyList<ShopSphere.Contract.Dtos.OrderDto>
@using ShopSphere.Contract.Enums

@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center">
    <h2>Orders</h2>
</div>

@if (!Model.Any())
{
    <p class="mt-3">No orders found.</p>
}
else
{
    <table class="table table-striped mt-3 align-middle">
        <thead>
            <tr>
                <th>Order</th>
                <th>Customer</th>
                <th>Mobile</th>
                <th>Status</th>
                <th>Payment</th>
                <th class="text-end">Total</th>
                <th class="text-end">Items</th>
                <th class="text-end">Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td class="text-break">@o.OrderNumber</td>
                <td class="text-break">@o.CustomerName</td>
                <td class="text-break">@o.Mobile</td>
                <td>@o.Status</td>
                <td>@(o.Payment is null ? PaymentStatus.Pending : o.Payment.Status)</td>
                <td class="text-end">@o.Total.ToString("0.00")</td>
                <td class="text-end">@o.Items.Count</td>
                <td class="text-end">@o.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                <td class="text-end">
                    <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
