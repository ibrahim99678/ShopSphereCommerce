@model IReadOnlyList<ShopSphere.Contract.Dtos.ProductDto>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center">
    <h2>Products</h2>
    <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn btn-primary">Create</a>
</div>

@if (!Model.Any())
{
    <p>No products found.</p>
}
else
{
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>Name</th>
                <th>Brand</th>
                <th>SKU</th>
                <th>Slug</th>
                <th>Category</th>
                <th class="text-end">Price</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Brand</td>
                <td>@p.Sku</td>
                <td>@p.Slug</td>
                <td>@p.CategoryName</td>
                <td class="text-end">@p.Price.ToString("0.00")</td>
                <td class="text-end">
                    <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
