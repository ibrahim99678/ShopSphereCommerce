@model IReadOnlyList<ShopSphere.Contract.Dtos.ProductImageDto>

@{
    var product = ViewBag.Product as ShopSphere.Contract.Dtos.ProductDto;
    ViewData["Title"] = "Product Images";
}

<div class="d-flex justify-content-between align-items-center">
    <h2>Product Images</h2>
    <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@product?.Id" class="btn btn-outline-secondary">Back</a>
</div>

@if (product is not null)
{
    <div class="mt-2">
        <strong>@product.Name</strong>
        <span class="text-muted">(@product.Sku)</span>
    </div>
}

@if (TempData["Error"] is string error && !string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger mt-3">@error</div>
}

<form asp-area="Admin" asp-controller="ProductImages" asp-action="Upload" asp-route-productId="@product?.Id" method="post" enctype="multipart/form-data" class="mt-3">
    <div class="input-group">
        <input type="file" name="file" class="form-control" accept="image/*" required />
        <button type="submit" class="btn btn-primary">Upload</button>
    </div>
</form>

@if (!Model.Any())
{
    <p class="mt-3">No images found.</p>
}
else
{
    <table class="table table-striped mt-3 align-middle">
        <thead>
            <tr>
                <th style="width: 120px;">Preview</th>
                <th>Url</th>
                <th class="text-end">Order</th>
                <th>Primary</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var img in Model)
        {
            <tr>
                <td>
                    <img src="@img.ImageUrl" class="product-img-admin rounded" alt="Product image" />
                </td>
                <td class="text-break">@img.ImageUrl</td>
                <td class="text-end">@img.SortOrder</td>
                <td>@(img.IsPrimary ? "Yes" : "No")</td>
                <td class="text-end">
                    <form asp-area="Admin" asp-controller="ProductImages" asp-action="Move" asp-route-id="@img.Id" asp-route-productId="@img.ProductId" asp-route-direction="-1" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Up</button>
                    </form>
                    <form asp-area="Admin" asp-controller="ProductImages" asp-action="Move" asp-route-id="@img.Id" asp-route-productId="@img.ProductId" asp-route-direction="1" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Down</button>
                    </form>
                    @if (!img.IsPrimary)
                    {
                        <form asp-area="Admin" asp-controller="ProductImages" asp-action="SetPrimary" asp-route-id="@img.Id" asp-route-productId="@img.ProductId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-primary">Set Primary</button>
                        </form>
                    }
                    <form asp-area="Admin" asp-controller="ProductImages" asp-action="Delete" asp-route-id="@img.Id" asp-route-productId="@img.ProductId" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
