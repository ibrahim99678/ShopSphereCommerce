@model ShopSphere.Contract.Dtos.ProductVariantDto

@{
    var product = ViewBag.Product as ShopSphere.Contract.Dtos.ProductDto;
    ViewData["Title"] = "Edit Variant";
}

<h2>Edit Variant</h2>

@if (product is not null)
{
    <div class="mb-3">
        <strong>@product.Name</strong>
        <span class="text-muted">(@product.Sku)</span>
    </div>
}

<form asp-area="Admin" asp-controller="ProductVariants" asp-action="Edit" method="post">
    <input asp-for="Id" type="hidden" />
    <input asp-for="ProductId" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Sku" class="form-label"></label>
        <input asp-for="Sku" class="form-control" />
        <span asp-validation-for="Sku" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Size" class="form-label"></label>
            <input asp-for="Size" class="form-control" />
            <span asp-validation-for="Size" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Color" class="form-label"></label>
            <input asp-for="Color" class="form-control" />
            <span asp-validation-for="Color" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="PriceOverride" class="form-label"></label>
            <input asp-for="PriceOverride" class="form-control" />
            <span asp-validation-for="PriceOverride" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="StockQuantity" class="form-label"></label>
            <input asp-for="StockQuantity" class="form-control" />
            <span asp-validation-for="StockQuantity" class="text-danger"></span>
        </div>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Index" asp-route-productId="@Model.ProductId" class="btn btn-outline-secondary">Cancel</a>
</form>

