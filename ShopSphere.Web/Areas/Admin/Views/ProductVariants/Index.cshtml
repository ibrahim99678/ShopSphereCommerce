@model IReadOnlyList<ShopSphere.Contract.Dtos.ProductVariantDto>

@{
    var product = ViewBag.Product as ShopSphere.Contract.Dtos.ProductDto;
    ViewData["Title"] = "Product Variants";
}

<div class="d-flex justify-content-between align-items-center">
    <h2>Product Variants</h2>
    <div class="d-flex gap-2">
        <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@product?.Id" class="btn btn-outline-secondary">Back</a>
        <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Create" asp-route-productId="@product?.Id" class="btn btn-primary">Add Variant</a>
    </div>
</div>

@if (product is not null)
{
    <div class="mt-2">
        <strong>@product.Name</strong>
        <span class="text-muted">(@product.Sku)</span>
    </div>
}

@if (!Model.Any())
{
    <p class="mt-3">No variants found.</p>
}
else
{
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>SKU</th>
                <th>Size</th>
                <th>Color</th>
                <th class="text-end">Price Override</th>
                <th class="text-end">Stock</th>
                <th>Active</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var v in Model)
        {
            <tr>
                <td>@v.Sku</td>
                <td>@v.Size</td>
                <td>@v.Color</td>
                <td class="text-end">@((v.PriceOverride is null) ? "-" : v.PriceOverride.Value.ToString("0.00"))</td>
                <td class="text-end">@v.StockQuantity</td>
                <td>@(v.IsActive ? "Yes" : "No")</td>
                <td class="text-end">
                    <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Edit" asp-route-id="@v.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form asp-area="Admin" asp-controller="ProductVariants" asp-action="Delete" asp-route-id="@v.Id" asp-route-productId="@v.ProductId" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

