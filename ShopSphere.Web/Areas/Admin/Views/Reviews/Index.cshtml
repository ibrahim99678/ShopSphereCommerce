@model IReadOnlyList<ShopSphere.Contract.Dtos.ReviewDto>

@{
    ViewData["Title"] = "Review Moderation";
}

<div class="d-flex justify-content-between align-items-center">
    <h2>Review Moderation</h2>
</div>

@if (!Model.Any())
{
    <p class="mt-3">No pending reviews.</p>
}
else
{
    <table class="table table-striped mt-3 align-middle">
        <thead>
            <tr>
                <th>Product</th>
                <th>Reviewer</th>
                <th class="text-end">Rating</th>
                <th>Title</th>
                <th>Comment</th>
                <th class="text-end">Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td class="text-break">
                    <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(r.ProductName) ? r.ProductName : $"Product #{r.ProductId}")</div>
                    <a asp-area="" asp-controller="Products" asp-action="Details" asp-route-id="@r.ProductId" class="link-primary">View product</a>
                </td>
                <td class="text-break">@r.ReviewerName</td>
                <td class="text-end">@r.Rating</td>
                <td class="text-break">@r.Title</td>
                <td class="text-break" style="max-width: 420px;">@r.Comment</td>
                <td class="text-end">@r.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                <td class="text-end">
                    <form asp-area="Admin" asp-controller="Reviews" asp-action="Approve" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@r.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-primary">Approve</button>
                    </form>
                    <form asp-area="Admin" asp-controller="Reviews" asp-action="Delete" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@r.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

