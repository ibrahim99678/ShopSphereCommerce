@model ShopSphere.Web.Areas.Admin.Controllers.UsersIndexViewModel

@{
    ViewData["Title"] = "Users & Roles";
}

<div class="d-flex justify-content-between align-items-center">
    <h2>Users & Roles</h2>
    <div>
        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Products</a>
        <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary">Categories</a>
    </div>
</div>

@if (!Model.Users.Any())
{
    <p>No users found.</p>
}
else
{
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>Email</th>
                <th>Full Name</th>
                <th>Email Confirmed</th>
                <th>Admin</th>
                <th>Customer</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var u in Model.Users)
        {
            var formId = $"roles-{u.Id}";
            <tr>
                <td>@u.Email</td>
                <td>@u.FullName</td>
                <td>@(u.EmailConfirmed ? "Yes" : "No")</td>
                <td>
                    <input type="checkbox" form="@formId" name="IsAdmin" value="true" @(u.IsAdmin ? "checked" : "") />
                </td>
                <td>
                    <input type="checkbox" form="@formId" name="IsCustomer" value="true" @(u.IsCustomer ? "checked" : "") />
                </td>
                <td class="text-end">
                    <form id="@formId" asp-area="Admin" asp-controller="Users" asp-action="UpdateRoles" method="post" class="d-inline">
                        <input type="hidden" name="UserId" value="@u.Id" />
                        <input type="hidden" name="IsAdmin" value="false" />
                        <input type="hidden" name="IsCustomer" value="false" />
                        <button type="submit" class="btn btn-sm btn-primary">Save</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
