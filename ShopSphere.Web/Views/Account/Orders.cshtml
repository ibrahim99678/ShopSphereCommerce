@model IReadOnlyList<ShopSphere.Contract.Dtos.OrderDto>
@using ShopSphere.Contract.Enums

@{
    ViewData["Title"] = "Orders";
}

<h2>Orders</h2>

@if (!Model.Any())
{
    <p>No orders found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Order Number</th>
                <th>Date</th>
                <th>Total</th>
                <th>Status</th>
                <th>Payment</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.OrderNumber</td>
                <td>@order.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td>@order.Total.ToString("0.00")</td>
                <td>@order.Status</td>
                <td>@(order.Payment is null ? PaymentStatus.Pending : order.Payment.Status)</td>
                <td class="text-end">
                    <a asp-controller="Account" asp-action="OrderDetails" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
