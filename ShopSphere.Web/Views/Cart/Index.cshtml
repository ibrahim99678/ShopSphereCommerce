@model ShopSphere.Contract.Dtos.ShoppingCartDto

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="d-flex justify-content-between align-items-center">
    <h2>Shopping Cart</h2>
    <div class="d-flex gap-2">
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">Continue Shopping</a>
        @if (Model.Items.Any())
        {
            <a asp-controller="Checkout" asp-action="Index" class="btn btn-primary">Checkout</a>
        }
        @if (Model.Items.Any())
        {
            <form asp-controller="Cart" asp-action="Clear" method="post" class="d-inline">
                <button type="submit" class="btn btn-outline-danger">Clear</button>
            </form>
        }
    </div>
</div>

@if (TempData["Success"] is string success && !string.IsNullOrWhiteSpace(success))
{
    <div class="alert alert-success mt-3">@success</div>
}

@if (TempData["Error"] is string error && !string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger mt-3">@error</div>
}

@if (!Model.Items.Any())
{
    <p class="mt-3">Your cart is empty.</p>
}
else
{
    <table class="table table-striped mt-3 align-middle">
        <thead>
            <tr>
                <th style="width: 90px;">Image</th>
                <th>Product</th>
                <th style="width: 180px;">Quantity</th>
                <th class="text-end" style="width: 140px;">Unit Price</th>
                <th class="text-end" style="width: 140px;">Line Total</th>
                <th style="width: 90px;"></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="product-img-cart rounded" alt="Product image" />
                    }
                </td>
                <td>
                    <div class="fw-semibold">@item.ProductName</div>
                    @if (!string.IsNullOrWhiteSpace(item.VariantLabel))
                    {
                        <div class="text-muted">@item.VariantLabel</div>
                    }
                </td>
                <td>
                    <form asp-controller="Cart" asp-action="Update" method="post" class="d-flex gap-2">
                        <input type="hidden" name="itemId" value="@item.Id" />
                        <input type="number" name="quantity" value="@item.Quantity" min="0" class="form-control" />
                        <button type="submit" class="btn btn-sm btn-primary">Update</button>
                    </form>
                </td>
                <td class="text-end">@item.UnitPrice.ToString("0.00")</td>
                <td class="text-end">@item.LineTotal.ToString("0.00")</td>
                <td class="text-end">
                    <form asp-controller="Cart" asp-action="Remove" method="post" class="d-inline">
                        <input type="hidden" name="itemId" value="@item.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <div class="d-flex justify-content-end mt-3">
        <div style="min-width: 320px;">
            <div class="d-flex justify-content-between">
                <div class="fw-semibold">Subtotal</div>
                <div>@Model.Subtotal.ToString("0.00")</div>
            </div>
            <div class="d-flex justify-content-between">
                <div class="fw-semibold">Total</div>
                <div>@Model.Total.ToString("0.00")</div>
            </div>
        </div>
    </div>
}
