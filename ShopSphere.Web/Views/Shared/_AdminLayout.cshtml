@using Microsoft.AspNetCore.Identity
@using ShopSphere.Contract.Services
@using ShopSphere.DAL.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject INotificationService NotificationService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShopSphere</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ShopSphere.Web.styles.css" asp-append-version="true" />
</head>
<body class="admin-body">
@{
    var userId = SignInManager.IsSignedIn(User) ? UserManager.GetUserId(User) : null;
    var unreadCount = string.IsNullOrWhiteSpace(userId) ? 0 : await NotificationService.GetUnreadCountAsync(userId);
}

<div class="admin-shell">
    <aside class="admin-sidebar border-end">
        <div class="admin-sidebar-header px-3 py-3 border-bottom">
            <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="text-decoration-none fw-semibold text-dark">Admin Panel</a>
        </div>
        <nav class="admin-nav p-2">
            <a class="admin-nav-link" asp-area="Admin" asp-controller="Home" asp-action="Index">Dashboard</a>
            <a class="admin-nav-link" asp-area="Admin" asp-controller="Orders" asp-action="Index">Orders</a>
            <a class="admin-nav-link" asp-area="Admin" asp-controller="Product" asp-action="Index">Products</a>
            <a class="admin-nav-link" asp-area="Admin" asp-controller="Category" asp-action="Index">Categories</a>
            <a class="admin-nav-link" asp-area="Admin" asp-controller="Inventory" asp-action="LowStock">Inventory</a>
            <a class="admin-nav-link" asp-area="Admin" asp-controller="Reviews" asp-action="Index">Reviews</a>
            <a class="admin-nav-link d-flex justify-content-between align-items-center" asp-area="Admin" asp-controller="Notifications" asp-action="Index">
                <span>Notifications</span>
                @if (unreadCount > 0)
                {
                    <span class="badge rounded-pill bg-danger">@unreadCount</span>
                }
            </a>
            <a class="admin-nav-link" asp-area="Admin" asp-controller="Users" asp-action="Index">Users</a>
        </nav>
        <div class="admin-sidebar-footer p-3 border-top">
            <div class="small text-muted text-truncate">@User.Identity?.Name</div>
            <div class="d-flex gap-2 mt-2">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">Store</a>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index","Home", new { area = "" })" method="post" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Logout</button>
                </form>
            </div>
        </div>
    </aside>

    <div class="admin-content">
        <header class="admin-topbar border-bottom">
            <div class="container-fluid py-2 d-flex justify-content-between align-items-center">
                <div class="fw-semibold">@ViewData["Title"]</div>
                <div class="d-flex gap-2 align-items-center">
                    <a class="btn btn-sm btn-outline-primary position-relative" asp-area="Admin" asp-controller="Notifications" asp-action="Index" title="Notifications" aria-label="Notifications">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2z"/>
                            <path d="M8 1.918l-.797.161A4.002 4.002 0 0 0 4 6c0 .628-.134 2.197-.459 3.742-.16.767-.376 1.566-.663 2.258h10.244c-.287-.692-.502-1.49-.663-2.258C12.134 8.197 12 6.628 12 6a4.002 4.002 0 0 0-3.203-3.92L8 1.917zM14.22 12c.223.447.481.801.78 1H1c.299-.199.557-.553.78-1C2.68 10.2 3 6.88 3 6c0-2.42 1.72-4.44 4.005-4.901a1 1 0 1 1 1.99 0A5.002 5.002 0 0 1 13 6c0 .88.32 4.2 1.22 6z"/>
                        </svg>
                        @if (unreadCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">@unreadCount</span>
                        }
                    </a>
                </div>
            </div>
        </header>

        <main class="admin-main container-fluid py-3">
            @RenderBody()
        </main>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
